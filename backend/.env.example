# Adatbazis (PostgreSQL)
# Helyben futo PostgreSQL szukseges. Hozz letre egy ures adatbazist
# (pl. "pawner_db"); a tablakat az alkalmazas automatikusan letrehozza
# (TypeORM synchronize fejlesztoi modban).
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=          # a PostgreSQL felhasznalo jelszava
DB_NAME=pawner_db

# JWT bejelentkezes
# Tetszoleges, hosszu, veletlen karakterlanc (titkos kulcs a tokenekhez).
# Demohoz az alabbi ertek is mukodik; eles kornyezetben csereld le sajatra.
JWT_SECRET=pawner_demo_jwt_secret
JWT_EXPIRATION=7d

# Alkalmazas
PORT=3000
NODE_ENV=development
PLATFORM_FEE_PERCENTAGE=10
# Fejleszteskor altalaban a sajat LAN IP-d 8081-es porton, pl. http://192.168.1.10:8081
FRONTEND_URL=http://localhost:8081

# Stripe (fizetes)
# Ingyenes Stripe fiok szukseges (https://dashboard.stripe.com).
# A TESZT kulcsokat hasznald (sk_test_... es pk_test_...).
# Dashboard > Developers > API keys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Cloudinary (kep-/dokumentumfeltoltes) 
# Ingyenes Cloudinary fiok szukseges (https://cloudinary.com).
# Az ertekek a Cloudinary Dashboard fooldalan talalhatok.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (Gmail SMTP) 
# Email kuldeshez (verifikacio, jelszo-visszaallitas) egy Gmail fiok kell.
# A MAIL_PASSWORD: Google Fiok > Biztonsag > 2-lepcsos azonositas > Alkalmazasjelszavak.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=                 # a kuldo Gmail cim
MAIL_PASSWORD=             # 16 karakteres Gmail app password
MAIL_FROM=                 # feladokent megjeleno email cim (altalaban = MAIL_USER)

# Alkalmazas metaadatok 
APP_NAME=Pawner
SUPPORT_EMAIL=               # support email cim ugyan az MAIL_USER-nel, de lehet mas is

# Biztonsag 
BCRYPT_ROUNDS=12

# Rate limiting 
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# Fajlfeltoltes
MAX_FILE_SIZE=10485760
MAX_FILES_PER_UPLOAD=10
MAX_IMAGES_PER_PET=10

# VERIFIKACIOS BEALLITASOK
EMAIL_VERIFICATION_EXPIRES_IN=15m
PASSWORD_RESET_EXPIRES_IN=1h

# UZLETI LOGIKA BEALLITASOK
MAX_PETS_PER_SHELTER=10
PAWPOINTS_PER_DOLLAR=25
MONTHLY_GOAL_RESET_DAYS=31
ADOPTION_REQUEST_EXPIRES_DAYS=7
PET_EDIT_WINDOW_HOURS=24
